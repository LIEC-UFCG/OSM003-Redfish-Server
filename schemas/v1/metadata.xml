<edmx:Edmx xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx" Version="4.0">
  <!-- Referências externas -->
  <edmx:Reference Uri="/schemas/v1/RedfishExtensions_v1.xml">
    <edmx:Include Namespace="RedfishExtensions.v1_0_0" Alias="Redfish"/>
</edmx:Reference>
<edmx:Reference Uri="/schemas/v1/Resource_v1.xml">
    <edmx:Include Namespace="Resource" Alias="Resource"/>
</edmx:Reference>
<edmx:Reference Uri="/schemas/v1/SessionCollection_v1.xml">
    <edmx:Include Namespace="SessionCollection" Alias="SessionCollection"/>
</edmx:Reference>
<edmx:Reference Uri="/schemas/v1/Session_v1.xml">
    <edmx:Include Namespace="Session" Alias="Session"/>
</edmx:Reference>
<edmx:Reference Uri="http://redfish.dmtf.org/schemas/v1/LogEntryCollection_v1.xml">
    <edmx:Include Namespace="LogEntryCollection" Alias="LogEntryCollection"/>
</edmx:Reference>


  <!-- Serviços de Dados -->
  <edmx:DataServices>
    <!-- Definição do SessionService -->
    <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="SessionService">
      <EntityType Name="SessionService">
        <Annotation Term="Redfish.Required"/>
        <Property Name="ServiceEnabled" Type="Edm.Boolean" Nullable="false"/>
        <Property Name="SessionTimeout" Type="Edm.Int32" Nullable="false"/>
        <NavigationProperty Name="Sessions" Type="SessionCollection.v1_8_0.SessionCollection" Nullable="false"/>
      </EntityType>
    </Schema>

    <!-- Definição do SessionCollection -->
    <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="SessionCollection.v1_8_0">
      <EntityType Name="SessionCollection" BaseType="Resource.ResourceCollection">
        <Annotation Term="Redfish.Required"/>
        <NavigationProperty Name="Members" Type="Collection(Session.Session)" Nullable="false"/>
      </EntityType>
    </Schema>

    <!-- Definição do Session -->
    <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="Session">
      <EntityType Name="Session">
        <Annotation Term="Redfish.Required"/>
        <Property Name="Id" Type="Edm.String" Nullable="false"/>
        <Property Name="Name" Type="Edm.String"/>
        <Property Name="Description" Type="Edm.String"/>
        <Property Name="UserName" Type="Edm.String"/>
      </EntityType>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
